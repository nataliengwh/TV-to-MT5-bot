METAAPI_TOKEN=your_metaapi_token_here
METAAPI_ACCOUNT_ID=your_account_id_here
WEBHOOK_SECRET=change_me_to_something_strong

# Daily auto-close time for XAUUSD positions (HKT, 24h format)
# Closes all open XAUUSD positions before the gold market daily gap
# US summer hours (EDT, Mar-Nov): gap at ~05:00 HKT → use 04:59
# US winter hours (EST, Nov-Mar): gap at ~06:00 HKT → use 05:59
XAUUSD_CLOSE_TIME=04:59
