# Copy this file to .env and fill in your real values.
# The .env file is loaded automatically by python-dotenv when the app starts.
# NEVER commit your real .env file to Git.

# ── MetaApi ────────────────────────────────────────────────────────────────
# Your MetaApi API token (from https://app.metaapi.cloud/token)
METAAPI_TOKEN=your_metaapi_token_here

# The Account ID of your MT5 account in MetaApi
# (from https://app.metaapi.cloud/accounts — shown after you add your broker account)
METAAPI_ACCOUNT_ID=your_account_id_here

# ── Webhook Security ───────────────────────────────────────────────────────
# A secret passphrase you invent. Must be included in every TradingView alert.
WEBHOOK_SECRET=change_me_to_something_strong
